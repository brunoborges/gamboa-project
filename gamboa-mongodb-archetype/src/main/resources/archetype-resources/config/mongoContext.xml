<beans xmlns="http://www.springframework.org/schema/beans"
	xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:context="http://www.springframework.org/schema/context"
	xsi:schemaLocation="http://www.springframework.org/schema/beans
           http://www.springframework.org/schema/beans/spring-beans.xsd
           http://www.springframework.org/schema/context
           http://www.springframework.org/schema/context/spring-context.xsd">

	<context:property-placeholder location="classpath:mongodb.properties" ignore-unresolvable="true" />

	<bean id="db" class="code.db.MongoFactoryBean">
		<property name="host" value="${mdb.host}" />
		<property name="port" value="${mdb.port}" />
		<property name="name" value="${mdb.name}" />
		<property name="username" value="${mdb.user}" />
		<property name="password" value="${mdb.pass}" />
	</bean>

</beans>
